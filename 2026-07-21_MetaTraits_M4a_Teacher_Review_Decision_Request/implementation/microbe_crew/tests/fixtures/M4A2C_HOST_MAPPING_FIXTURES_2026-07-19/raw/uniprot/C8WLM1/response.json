99"}],"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"},{"evidenceCode":"ECO:0000305"}]},"physiologicalReactions":[{"directionType":"left-to-right","reactionCrossReference":{"database":"Rhea","id":"RHEA:62545"},"evidences":[{"evidenceCode":"ECO:0000305","source":"PubMed","id":"29761785"}]}]},{"commentType":"COFACTOR","cofactors":[{"name":"FAD","evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"}],"cofactorCrossReference":{"database":"ChEBI","id":"CHEBI:57692"}}]},{"commentType":"COFACTOR","cofactors":[{"name":"[4Fe-4S] cluster","evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"}],"cofactorCrossReference":{"database":"ChEBI","id":"CHEBI:49883"}}]},{"commentType":"BIOPHYSICOCHEMICAL PROPERTIES","kineticParameters":{"michaelisConstants":[{"constant":94.6,"unit":"uM","substrate":"digoxin","evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"}]}],"note":{"texts":[{"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"}],"value":"kcat is 0.23 sec(-1) for the reduction of digoxin."}]}}},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000305","source":"PubMed","id":"29761785"}],"value":"May form a membrane-associated complex with Cgr1"}],"commentType":"SUBUNIT"},{"commentType":"SUBCELLULAR LOCATION","subcellularLocations":[{"location":{"value":"Cell membrane","id":"SL-0039"},"topology":{"value":"Peripheral membrane protein","id":"SL-9903"},"orientation":{"evidences":[{"evidenceCode":"ECO:0000305","source":"PubMed","id":"29761785"}],"value":"Extracellular side","id":"SL-9911"}}]},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"23869020"}],"value":"Is highly up-regulated by digoxin and other cardiac glycosides containing unsaturated butyrolactone rings, such as digitoxin, digoxigenin, and, to a lesser extent, ouabain. Is repressed by arginine but not by ornithine. Part of an operon that consists of cgr1 and cgr2"}],"commentType":"INDUCTION"},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000255","source":"PROSITE-ProRule","id":"PRU00648"}],"value":"Predicted to be exported by the Tat system. The position of the signal peptide cleavage has not been experimentally proven"}],"commentType":"PTM"},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"23869020"},{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"}],"value":"Digoxin is a toxic chemical produced by plants that, in low doses, can be used to treat heart failure and arrhythmia. cgr operon presence and abundance predicted the extent of drug inactivation by human gut microbial communities in ex vivo incubations, and is restricted to E.lenta species. Data about the gut microbes in nearly 1,900 people from three continents revealed that bacteria that can produce Cgr2 were present in the guts of more than 40% of the individuals, although often in low abundance"}],"commentType":"MISCELLANEOUS"},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000305"}],"value":"Belongs to the FAD-dependent oxidoreductase 2 family"}],"commentType":"SIMILARITY"}],"features":[{"type":"Signal","location":{"start":{"value":1,"modifier":"EXACT"},"end":{"value":48,"modifier":"EXACT"}},"description":"Tat-type signal","evidences":[{"evidenceCode":"ECO:0000255","source":"PROSITE-ProRule","id":"PRU00648"}]},{"type":"Chain","location":{"start":{"value":49,"modifier":"EXACT"},"end":{"value":560,"modifier":"EXACT"}},"description":"Digoxin reductase","featureId":"PRO_5002992288"},{"type":"Mutagenesis","location":{"start":{"value":82,"modifier":"EXACT"},"end":{"value":82,"modifier":"EXACT"}},"description":"Decrease in catalytic activity. Still binds a [4Fe-4S] cluster.","evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"29761785"}],"alternativeSequence":{"originalSequence":"C","alternativeSequences":["A"]}},{"type":"Mutagenesis","location":{"start":{"value":158,"modifier":"EXACT"},"end":{"value":158,"modifier":"EXACT"}},"d